        </Parameter><Parameter><Name>AxisVelocityLimit</Name><Comment TxtId=""><![CDATA[Maximum allowed axis velocity in percent of the nominal velocity. Exceeding this limit causes a soft stop.]]></Comment><BaseType GUID="{18071995-0000-0000-0000-00000000000e}">LREAL</BaseType><Unit><![CDATA[%]]></Unit><Default><Value>50</Value></Default><PTCID>#x0000000A</PTCID><ContextId>1</ContextId></Parameter><Parameter><Name>AxisMotorTorqueLimit</Name><Comment TxtId=""><![CDATA[Maximum allowed motor torque in percent of the nominal motor torque. Exceeding this limit causes a soft stop and prevents enabling the motors. The current limit and the I2t limit are always active.]]></Comment><BaseType GUID="{18071995-0000-0000-0000-00000000000e}">LREAL</BaseType><Unit><![CDATA[%]]></Unit><Default><Value>80</Value></Default><PTCID>#x0000000B</PTCID><ContextId>1</ContextId></Parameter><Parameter><Name>AxisMotorTorqueSaturation</Name><Comment TxtId=""><![CDATA[Maximum applied motor torque in percent of the nominal motor torque. Exceeding this limit only saturates the applied torque and causes no stop or error. The current limit and the I2t limit are always active.]]></Comment><BaseType GUID="{18071995-0000-0000-0000-00000000000e}">LREAL</BaseType><Unit><![CDATA[%]]></Unit><Default><Value>40</Value></Default><PTCID>#x0000000D</PTCID><ContextId>1</ContextId></Parameter><Parameter><Name>AxisSensorTorqueLimit</Name><Comment TxtId=""><![CDATA[Maximum allowed torque measured at the sensors in percent of the nominal torque. Exceeding this limit causes a soft stop.]]></Comment><BaseType GUID="{18071995-0000-0000-0000-00000000000e}">LREAL</BaseType><Unit><![CDATA[%]]></Unit><Default><Value>40</Value></Default><PTCID>#x0000000C</PTCID><ContextId>1</ContextId></Parameter><Parameter><Name>AxisPositionSoftReserve</Name><Comment TxtId=""><![CDATA[Additional software reserve (in degrees) before the hardware axis position limit is reached. If an axis reaches this reserve, a soft stop is engaged.]]></Co