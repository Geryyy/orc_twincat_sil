									<BitSize>64</BitSize>
									<BitOffs>64</BitOffs>
									<Unit><![CDATA[m/s]]></Unit>
									<Default>
										<Min>0</Min>
										<Max>2.75</Max>
										<Value>0.7</Value>
									</Default>
								</SubItem>
