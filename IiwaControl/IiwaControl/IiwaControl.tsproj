									<Name>PositionSoftReserve</Name>
									<Type GUID="{18071995-0000-0000-0000-00000000000E}">LREAL</Type>
									<Comment TxtId=""><![CDATA[Specifies the soft reserve for all linear axes.]]></Comment>
									<BitSize>64</BitSize>
									<BitOffs>0</BitOffs>
									<Unit><![CDATA[m]]></Unit>
									<Default>
										<Min>0</Min>
										<Value>.1</Value>
									</Default>
								</SubItem>
								<SubItem>
									<Name>VelocityLimit</Name>
									<Type GUID="{18071995-0000-0000-0000-00000000000E}">LREAL</Type>
