						<Parameters>
							<Parameter>
								<Name>TraceLevelMax</Name>
								<Comment><![CDATA[Controls the amount of log messages.]]></Comment>
								<BitSize>32</BitSize>
								<BaseType GUID="{8007AE3B-86BB-40F2-B385-EF87FCC239A4}">TcTraceLevel</BaseType>
								<PTCID>#x03002103</PTCID>
								<ContextId>1</ContextId>
							</Parameter>
							<Parameter>
								<Name>AxisVelocityLimit</Name>
								<Comment TxtId=""><![CDATA[Maximum allowed axis velocity in percent of the nominal velocity. Exceeding this limit causes a soft stop.]]></Comment>
								<BitSize>64</BitSize>
								<BaseType GUID="{18071995-0000-0000-0000-00000000000E}">LREAL</BaseType>
								<Unit><![CDATA[%]]></Unit>
								<Default>
									<Value>50</Value>
								</Default>
								<PTCID>#x0000000a</PTCID>
								<ContextId>1</ContextId>
							</Parameter>
							<Parameter>
								<Name>AxisMotorTorqueLimit</Name>
								<Comment TxtId=""><![CDATA[Maximum allowed motor torque in percent of the nominal motor torque. Exceeding this limit causes a soft stop and prevents enabling the motors. The current limit and the I2t limit are always active.]]></Comment>
								<BitSize>64</BitSize>
								<BaseType GUID="{18071995-0000-0000-0000-00000000000E}">LREAL</BaseType>
								<Unit><![CDATA[%]]></Unit>
								<Default>
									<Value>80</Value>
								</Default>
								<PTCID>#x0000000b</PTCID>
								<ContextId>1</ContextId>
							</Parameter>
							<Parameter>
								<Name>AxisMotorTorqueSaturation</Name>
								<Comment TxtId=""><![CDATA[Maximum applied motor torque in percent of the nominal motor torque. Exceeding this limit only saturates the applied torque and causes no stop or error. The current limit and the I2t limit are always active.]]></Comment>
								<BitSize>64</BitSize>
								<BaseType GUID="{18071995-0000-0000-0000-00000000000E}">LREAL</BaseType>
								<Unit><![CDATA[%]]></Unit>
								<Default>
									<Value>40</Value>
								</Default>
								<PTCID>#x0000000d</PTCID>
								<ContextId>1</ContextId>
							</Parameter>
							<Parameter>
								<Name>AxisSensorTorqueLimit</Name>
								<Comment TxtId=""><![CDATA[Maximum allowed torque measured at the sensors in percent of the nominal torque. Exceeding this limit causes a soft stop.]]></Comment>
								<BitSize>64</BitSize>
								<BaseType GUID="{18071995-0000-0000-0000-00000000000E}">LREAL</BaseType>
								<Unit><![CDATA[%]]></Unit>
								<Default>
									<Value>40</Value>
								</Default>
								<PTCID>#x0000000c</PTCID>
								<ContextId>1</ContextId>
							</Parameter>
							<Parameter>
								<Name>AxisPositionSoftReserve</Name>
								<Comment TxtId=""><![CDATA[Additional software reserve (in degrees) before the hardware axis position limit is reached. If an axis reaches this reserve, a soft stop is engaged.]]></Comment>
								<BitSize>64</BitSize>
								<BaseType GUID="{18071995-0000-0000-0000-00000000000E}">LREAL</BaseType>
								<Unit><![CDATA[°]]></Unit>
								<Default>
									<Value>10</Value>
								</Default>
								<PTCID>#x0000000e</PTCID>
								<ContextId>1</ContextId>
							</Parameter>
							<Parameter>
								<Name>LinearAxisParameters</Name>
								<BitSize>384</BitSize>
