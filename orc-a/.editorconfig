# EditorConfig for the ORC project
# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

# C / C++
[*.{c,cc,cpp,cxx,h,hh,hpp,hxx,ipp,inl}]
indent_style = space
indent_size = 4

# Python
[*.{py,pyi}]
indent_style = space
indent_size = 4

# CMake
[{CMakeLists.txt,*.cmake}]
indent_style = space
indent_size = 4

# YAML
[*.{yml,yaml}]
indent_size = 2

# JSON
[*.{json,json5}]
indent_size = 2

# TOML
[*.toml]
indent_size = 2

# Markdown — preserve trailing whitespace (line breaks)
[*.md]
indent_size = 2
trim_trailing_whitespace = false

# Shell scripts
[*.{sh,bash,zsh}]
indent_style = space
indent_size = 2

# Makefiles require tabs
[{Makefile,makefile,GNUmakefile,*.mk}]
indent_style = tab
