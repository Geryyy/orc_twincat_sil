# MJB presets — large binaries are tracked via Git LFS (see .gitattributes).
# Only the .gitkeep marker and the .mjb files are kept; everything else
# (e.g. transient generation by-products) is ignored.
models/presets/**
!models/presets/.gitkeep
!models/presets/*.mjb

# Paper working directory (lives on feat/paper, not here)
__RAP__ORC_Paper/

# Regenerated sim output for the lemniscate experiment (~7 MB).
