<mujoco model="two_dof">
  <compiler angle="degree"/>
  <option timestep="0.01"/>

  <worldbody>
    <body name="base" pos="0 0 0">
      <joint name="joint1" type="hinge" axis="0 0 1" pos="0 0 0"/>
      <geom name="link1" type="capsule" size="0.05 0.3" pos="0 0 0.3" rgba="0.8 0.2 0.2 1"/>

      <body name="link2" pos="0 0 0.6">
        <joint name="joint2" type="hinge" axis="0 1 0" pos="0 0 0"/>
        <geom name="link2_geom" type="capsule" size="0.05 0.3" pos="0 0 0.3" rgba="0.2 0.2 0.8 1"/>
      </body>
    </body>
  </worldbody>

  <actuator>
    <motor joint="joint1" ctrlrange="-1 1"/>
    <motor joint="joint2" ctrlrange="-1 1"/>
  </actuator>
</mujoco>
